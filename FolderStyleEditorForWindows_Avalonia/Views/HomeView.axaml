<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FolderStyleEditorForWindows.ViewModels"
             xmlns:services="using:FolderStyleEditorForWindows.Services"
             xmlns:views="using:FolderStyleEditorForWindows.Views"
             xmlns:vc="using:FolderStyleEditorForWindows.ValueConverters"
             xmlns:controls="using:FolderStyleEditorForWindows.Controls"
             xmlns:c="using:Avalonia.Controls"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:ia="using:Avalonia.Xaml.Interactions.Animated"
             xmlns:behaviors="using:FolderStyleEditorForWindows.Behaviors"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             mc:Ignorable="d" d:DesignWidth="404" d:DesignHeight="762"
             x:Class="FolderStyleEditorForWindows.Views.HomeView"
             x:DataType="vm:MainViewModel">
   <UserControl.Styles>
       <Style Selector="Button#btnAboutInfo">
           <Setter Property="Width" Value="30"/>
           <Setter Property="Height" Value="30"/>
           <Setter Property="Padding" Value="10,0,10,10"/>
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderBrush" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="CornerRadius" Value="999"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="HorizontalContentAlignment" Value="Center"/>
           <Setter Property="VerticalContentAlignment" Value="Center"/>
           <Setter Property="Template">
               <ControlTemplate>
                   <Border Name="PART_Border"
                           Background="{TemplateBinding Background}"
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="{TemplateBinding CornerRadius}"
                           Padding="{TemplateBinding Padding}">
                       <ContentPresenter Name="PART_ContentPresenter"
                                         Content="{TemplateBinding Content}"
                                         ContentTemplate="{TemplateBinding ContentTemplate}"
                                         VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                         HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                   </Border>
               </ControlTemplate>
           </Setter>
       </Style>
       <Style Selector="Button#btnAboutInfo /template/ Border#PART_Border">
           <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
           <Setter Property="RenderTransform" Value="scale(1)"/>
           <Setter Property="Transitions">
               <Transitions>
                   <TransformOperationsTransition Property="RenderTransform" Duration="0.11" Easing="CubicEaseOut"/>
               </Transitions>
           </Setter>
       </Style>
       <Style Selector="Button#btnAboutInfo Svg#AboutInfoIcon">
           <Setter Property="Opacity" Value="0.4"/>
       </Style>
       <Style Selector="Button#btnAboutInfo Border#AboutInfoShadowHost">
           <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
       </Style>
       <Style Selector="Button#btnAboutInfo:pointerover Svg#AboutInfoIcon">
           <Setter Property="Opacity" Value="0.76"/>
       </Style>
       <Style Selector="Button#btnAboutInfo:pointerover Border#AboutInfoShadowHost">
           <Setter Property="BoxShadow" Value="{StaticResource Shadow1}"/>
       </Style>
       <Style Selector="Button#FolderWordButton">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderBrush" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="ClipToBounds" Value="False"/>
           <Setter Property="Padding" Value="0"/>
           <Setter Property="MinHeight" Value="0"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="Template">
               <ControlTemplate>
                   <Border Name="PART_Border"
                           Background="{TemplateBinding Background}"
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}"
                           CornerRadius="{TemplateBinding CornerRadius}"
                           ClipToBounds="False"
                           Padding="{TemplateBinding Padding}">
                       <ContentPresenter Name="PART_ContentPresenter"
                                         Content="{TemplateBinding Content}"
                                         ContentTemplate="{TemplateBinding ContentTemplate}"
                                         VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                         HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                   </Border>
               </ControlTemplate>
           </Setter>
       </Style>
       <Style Selector="ScrollViewer.HomeHistoryScrollHost ScrollBar">
           <Setter Property="CornerRadius" Value="999"/>
       </Style>
        <Style Selector="ScrollViewer.HomeHistoryScrollHost ScrollBar /template/ Thumb">
            <Setter Property="Background" Value="#F0B8B6B2"/>
            <Setter Property="BorderBrush" Value="#00FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
        </Style>
        <Style Selector="ScrollViewer.HomeHistoryScrollHost ScrollBar:pointerover /template/ Thumb">
            <Setter Property="Background" Value="#F4C4C1BC"/>
        </Style>
        <Style Selector="ScrollViewer.HomeHistoryScrollHost ScrollBar:pressed /template/ Thumb">
            <Setter Property="Background" Value="#F8CFCCC7"/>
        </Style>
   </UserControl.Styles>
   <UserControl.Resources>
       <vc:FolderTagBorderBrushConverter x:Key="FolderTagBorderBrushConverter"/>
       <LinearGradientBrush x:Key="FolderWordAnimatedBrush"
                            StartPoint="0%,34%"
                            EndPoint="160%,66%"
                            SpreadMethod="Repeat">
           <GradientStop Color="#7b61ff" Offset="0"/>
           <GradientStop Color="#46c4ff" Offset="0.2"/>
           <GradientStop Color="#40dd88" Offset="0.4"/>
           <GradientStop Color="#ffb848" Offset="0.6"/>
           <GradientStop Color="#ff7a99" Offset="0.8"/>
           <GradientStop Color="#7b61ff" Offset="1"/>
       </LinearGradientBrush>
   </UserControl.Resources>
   <Grid RowDefinitions="54, 1*, 1*">
        
        <!-- Title Bar Area -->
        <DockPanel Grid.Row="0">
            <Grid ColumnDefinitions="*,Auto" Margin="12,0">
                <controls:TitleBarButtons Grid.Column="1"
                                          ShowBack="False"
                                          ShowMinimize="True"
                                          ShowClose="True"/>
            </Grid>
        </DockPanel>

        <!-- Drop Zone Display-->
        <Border Grid.Row="1" Name="dropZone" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0" Margin="0" Background="Transparent">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Grid HorizontalAlignment="Center" ClipToBounds="False" Margin="0">
                    <WrapPanel HorizontalAlignment="Center" Margin="28,0" ItemHeight="34" ClipToBounds="False">
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg2Brush}"
                                   Opacity="0.9"
                                   VerticalAlignment="Center"
                                   Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Home_DragZone_Part1]}"/>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg2Brush}"
                                   Opacity="0.9"
                                   VerticalAlignment="Center"
                                   Text=" "/>
                        <Button Name="FolderWordButton"
                                Classes="HoverFloat"
                                behaviors:HoverFloatBehavior.IsEnabled="True"
                                behaviors:HoverFloatBehavior.HoverScale="1.05"
                                behaviors:HoverFloatBehavior.PressScale="0.92"
                                behaviors:HoverFloatBehavior.MaxOffsetX="1.6"
                                behaviors:HoverFloatBehavior.MaxOffsetY="1.2"
                                behaviors:HoverFloatBehavior.LerpFactor="0.2"
                                VerticalAlignment="Center">
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Home_DragZone_Part2]}">
                                <TextBlock.Foreground>
                                    <StaticResource ResourceKey="FolderWordAnimatedBrush"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Button>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg2Brush}"
                                   Opacity="0.9"
                                   VerticalAlignment="Center"
                                   Text=" "/>
                        <TextBlock FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg2Brush}"
                                   Opacity="0.9"
                                   VerticalAlignment="Center"
                                   Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Home_DragZone_Part3]}"/>
                    </WrapPanel>
                    <Button Name="btnAboutInfo"
                            Classes="HoverFloat"
                            behaviors:HoverFloatBehavior.IsEnabled="True"
                            behaviors:HoverFloatBehavior.HoverScale="1.06"
                            behaviors:HoverFloatBehavior.PressScale="0.9"
                            behaviors:HoverFloatBehavior.MaxOffsetX="2.2"
                            behaviors:HoverFloatBehavior.MaxOffsetY="2.2"
                            behaviors:HoverFloatBehavior.LerpFactor="0.22"
                            Background="Transparent"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-8,-6,0">
                        <Border Name="AboutInfoShadowHost"
                                Background="Transparent"
                                CornerRadius="999"
                                Padding="2"
                                ClipToBounds="False">
                            <svg:Svg x:Name="AboutInfoIcon"
                                     Width="17"
                                     Height="17"
                                     Css="{DynamicResource SvgCss}"/>
                        </Border>
                    </Button>
                    <views:PerformanceBadge x:Name="HomeTitlePerformanceBadge"
                                            x:DataType="services:ComponentFpsBadgeSource"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Margin="-10,-20,0,0"
                                            Label="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceBadge_Label_HomeTitle]}"
                                            ValueText="{Binding HomeTitleDisplay}"
                                            IsVisible="{Binding IsEnabled}"/>
                </Grid>
                <TextBlock Name="ClickHintText"
                           Classes="HoverFloat"
                           behaviors:HoverFloatBehavior.IsEnabled="True"
                           behaviors:HoverFloatBehavior.HoverScale="1.06"
                           behaviors:HoverFloatBehavior.PressScale="0.9"
                           behaviors:HoverFloatBehavior.MaxOffsetX="1.8"
                           behaviors:HoverFloatBehavior.MaxOffsetY="1.2"
                           behaviors:HoverFloatBehavior.LerpFactor="0.2"
                           Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Home_ClickHint]}"
                           Foreground="{StaticResource Fg2Brush}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Background="Transparent"
                           Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- History -->
       <DockPanel Grid.Row="2" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0 16 0 0">
           <Border Width="368"
                   CornerRadius="{StaticResource RadiusLg}"
                   Background="#66FFFFFF"
                   BoxShadow="{StaticResource Shadow1}"
                   BorderBrush="{StaticResource LineBrush}"
                   BorderThickness="1"
                   Padding="14"
                   ClipToBounds="False"> <!-- 淇闃村奖瑁佸壀闂 -->
               <StackPanel>
                  <Grid ColumnDefinitions="*,Auto" Margin="0 0 0 12">
                      <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Home_History_Title]}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Fg1Brush}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <Button Name="btnClearHistory" Classes="Btn BtnGhost BtnDanger Light" Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Home_History_Clear]}" Height="28" Padding="10,0"
                            Command="{Binding ClearHistoryCommand}" IsVisible="{Binding History.Count}" Grid.Column="1" Background="Transparent"
                            Margin="0,-2,0,0"/>
                  </Grid>
                   <ScrollViewer MaxHeight="188.4"
                                 Classes="HomeHistoryScrollHost"
                                 IsVisible="{Binding History.Count}"
                                 Margin="-10,0,0,0"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              ClipToBounds="False">
                       <i:Interaction.Behaviors>
                           <ia:VerticalScrollViewerAnimatedBehavior/>
                           <behaviors:AutoHideScrollBehavior VisibleOpacity="0.62"/>
                       </i:Interaction.Behaviors>
                       <ListBox Name="historyList" ItemsSource="{Binding History}" Background="Transparent" BorderThickness="0" ClipToBounds="False" Padding="0,2,0,0">
                           <ListBox.ItemContainerTheme>
                               <ControlTheme TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                   <Setter Property="Padding" Value="0"/>
                                   <Setter Property="Margin" Value="0,0,0,10"/>
                                   <Setter Property="ClipToBounds" Value="False"/>
                                   <Style Selector="^:pointerover /template/ ContentPresenter">
                                       <Setter Property="Background" Value="Transparent"/>
                                   </Style>
                                   <Style Selector="^:selected /template/ ContentPresenter">
                                       <Setter Property="Background" Value="Transparent"/>
                                   </Style>
                                   <Style Selector="^:selected:focus /template/ ContentPresenter">
                                       <Setter Property="Background" Value="Transparent"/>
                                   </Style>
                               </ControlTheme>
                           </ListBox.ItemContainerTheme>
                           <ListBox.ItemTemplate>
                               <DataTemplate>
                                   <Button Classes="Btn BtnHistory" Command="{Binding $parent[UserControl].DataContext.OpenFromHistoryCommand}" CommandParameter="{Binding}"
                                           Height="30.8" HorizontalContentAlignment="Stretch"
                                           Background="Transparent" BorderThickness="0" Margin="14,0,0,0">
                                       <Grid HorizontalAlignment="Stretch">
                                           <Grid.ColumnDefinitions>
                                               <ColumnDefinition Width="*"/>
                                               <ColumnDefinition Width="Auto"/>
                                           </Grid.ColumnDefinitions>
                                           
                                           <!-- 文件夹路径文本 -->
                                           <TextBlock Grid.Column="0"
                                                      Text="{Binding Converter={StaticResource PathDisplayConverter}}"
                                                      Foreground="{StaticResource Fg2Brush}"
                                                      VerticalAlignment="Center"
                                                      FontWeight="SemiBold"
                                                      TextTrimming="CharacterEllipsis"
                                                      Margin="0"/>
                                           
                                           <!-- 文件夹状态标签 -->
                                           <Border Grid.Column="1"
                                                   Name="folderTag"
                                                   Background="{StaticResource FolderTagBgLightBrush}"
                                                   BorderThickness="1"
                                                   CornerRadius="14"
                                                   Height="28"
                                                   Padding="8,0"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,-0,-14,0"> <!-- 璋冩暣Margin锛屾姷娑圔utton鐨勫彸渚у唴杈硅窛 -->
                                               <Border.BorderBrush>
                                                   <MultiBinding Converter="{StaticResource FolderTagBorderBrushConverter}">
                                                       <Binding />
                                                       <Binding Path="$parent[UserControl].DataContext.IsElevationSessionActive"/>
                                                   </MultiBinding>
                                               </Border.BorderBrush>
                                               <TextBlock Text="{Binding Converter={StaticResource FolderNameConverter}}"
                                                          Foreground="{StaticResource Fg2Brush}"
                                                          VerticalAlignment="Center"
                                                          FontWeight="SemiBold"
                                                          FontSize="12"
                                                          TextTrimming="CharacterEllipsis"/>
                                           </Border>
                                           
                                           <!-- 娓愬彉閬僵 -->
                                           <Border Grid.Column="0"
                                                   ZIndex="1"
                                                   HorizontalAlignment="Right"
                                                   IsVisible="True">
                                               <Border.Width>
                                                   <MultiBinding Converter="{StaticResource HistoryPathFadeWidthConverter}">
                                                       <Binding />
                                                       <Binding Path="#folderTag.Bounds.Width"/>
                                                   </MultiBinding>
                                               </Border.Width>
                                               <Border.Background>
                                                   <LinearGradientBrush StartPoint="1,0.5" EndPoint="0,0.5">
                                                       <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                       <GradientStop Color="#BFFFFFFF" Offset="0.7"/>
                                                       <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                                   </LinearGradientBrush>
                                               </Border.Background>
                                           </Border>
                                       </Grid>
                                   </Button>
                               </DataTemplate>
                           </ListBox.ItemTemplate>
                       </ListBox>
                   </ScrollViewer>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Home_History_Empty]}" Foreground="{StaticResource Fg3Brush}" FontSize="12"
                               IsVisible="{Binding !History.Count}" HorizontalAlignment="Center" Margin="0,20"/>
               </StackPanel>
             </Border>
         </DockPanel>
     </Grid>
</UserControl>
