<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:FolderStyleEditorForWindows.Services"
             xmlns:behaviors="using:FolderStyleEditorForWindows.Behaviors"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:ia="using:Avalonia.Xaml.Interactions.Animated"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             x:Class="FolderStyleEditorForWindows.Views.InterruptDialog"
             x:DataType="services:InterruptDialogState"
             ZIndex="12000"
             IsHitTestVisible="{Binding IsHitTestVisible}">
  <UserControl.Styles>
    <Style Selector="Button.DialogLinkButton">
      <Setter Property="behaviors:HoverFloatBehavior.IsEnabled" Value="True"/>
      <Setter Property="behaviors:HoverFloatBehavior.HoverScale" Value="1.06"/>
      <Setter Property="behaviors:HoverFloatBehavior.PressScale" Value="0.92"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetX" Value="2.4"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetY" Value="2.4"/>
      <Setter Property="behaviors:HoverFloatBehavior.LerpFactor" Value="0.22"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="11"/>
      <Setter Property="BorderBrush" Value="#EEAAAAAA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="#66FFFFFF"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.DialogLinkButton:pointerover">
      <Setter Property="Background" Value="{Binding RelativeSource={RelativeSource Self}, Path=Background}"/>
      <Setter Property="BorderBrush" Value="{Binding RelativeSource={RelativeSource Self}, Path=BorderBrush}"/>
    </Style>
    <Style Selector="Button.DialogSectionToggle">
      <Setter Property="behaviors:HoverFloatBehavior.IsEnabled" Value="True"/>
      <Setter Property="behaviors:HoverFloatBehavior.HoverScale" Value="1.03"/>
      <Setter Property="behaviors:HoverFloatBehavior.PressScale" Value="0.95"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetX" Value="1.4"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetY" Value="1.2"/>
      <Setter Property="behaviors:HoverFloatBehavior.LerpFactor" Value="0.2"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="CornerRadius" Value="11"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="BorderBrush" Value="#DDE0E5EA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="#59FFFFFF"/>
    </Style>
    <Style Selector="Button.DialogTextToggle">
      <Setter Property="behaviors:HoverFloatBehavior.IsEnabled" Value="True"/>
      <Setter Property="behaviors:HoverFloatBehavior.HoverScale" Value="1.03"/>
      <Setter Property="behaviors:HoverFloatBehavior.PressScale" Value="0.95"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetX" Value="1.4"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetY" Value="1.2"/>
      <Setter Property="behaviors:HoverFloatBehavior.LerpFactor" Value="0.2"/>
      <Setter Property="BorderBrush" Value="#E1E4EA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="#7AFFFFFF"/>
      <Setter Property="CornerRadius" Value="11"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.DialogInlineLink">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
    </Style>
    <Style Selector="Button.DialogInlineLink:pointerover">
      <Setter Property="Opacity" Value="0.75"/>
    </Style>
    <Style Selector="CheckBox.DialogCheckbox">
      <Setter Property="behaviors:HoverFloatBehavior.IsEnabled" Value="True"/>
      <Setter Property="behaviors:HoverFloatBehavior.HoverScale" Value="1.03"/>
      <Setter Property="behaviors:HoverFloatBehavior.PressScale" Value="0.95"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetX" Value="1.2"/>
      <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetY" Value="1.2"/>
      <Setter Property="Foreground" Value="{StaticResource Fg3Brush}"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    <Style Selector="Button.DialogContextMenuButton">
      <Setter Property="behaviors:HoverFloatBehavior.IsEnabled" Value="True"/>
      <Setter Property="behaviors:HoverFloatBehavior.HoverScale" Value="1.03"/>
      <Setter Property="behaviors:HoverFloatBehavior.PressScale" Value="0.95"/>
      <Setter Property="Background" Value="#FFFFFFFF"/>
      <Setter Property="BorderBrush" Value="#EEAAAAAA"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="Button.DialogTabButton">
      <Setter Property="Background" Value="#73FFFFFF"/>
      <Setter Property="BorderBrush" Value="#E3E7ED"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="11"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="Foreground" Value="{StaticResource Fg2Brush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="MinWidth" Value="110"/>
    </Style>
    <Style Selector="Button.DialogTabButton.selected">
      <Setter Property="Background" Value="#FFF3ECE7"/>
      <Setter Property="BorderBrush" Value="#D6B9A7"/>
      <Setter Property="Foreground" Value="{StaticResource Fg1Brush}"/>
    </Style>
  </UserControl.Styles>

  <UserControl.DataTemplates>
    <DataTemplate x:DataType="services:DialogNumberFieldItem">
      <Border MinHeight="118"
              Margin="0,0,0,10"
              Background="#82FFFFFF"
              BorderBrush="#E3E7ED"
              BorderThickness="1"
              CornerRadius="12"
              Padding="14,12">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding Label}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource Fg1Brush}"
                     TextWrapping="Wrap"/>
          <TextBox Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Width="108"
                   HorizontalAlignment="Left"
                   Padding="10,8"
                   BorderBrush="#DFE4EB"
                   Background="#FFFFFFFF"/>
          <TextBlock Text="{Binding Description}"
                     IsVisible="{Binding HasDescription}"
                     FontSize="11"
                     Foreground="{StaticResource Fg3Brush}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding ErrorText}"
                     IsVisible="{Binding HasError}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#D46258"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:DataType="services:DialogToggleFieldItem">
      <Border MinHeight="118"
              Margin="0,0,0,10"
              Background="#82FFFFFF"
              BorderBrush="#E3E7ED"
              BorderThickness="1"
              CornerRadius="12"
              Padding="14,12">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="12">
            <TextBlock Text="{Binding Label}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Fg1Brush}"
                       TextWrapping="Wrap"/>
            <CheckBox Grid.Column="1"
                      Classes="DialogCheckbox"
                      Margin="0"
                      VerticalAlignment="Top"
                      IsChecked="{Binding Value}"/>
          </Grid>
          <TextBlock Text="{Binding Description}"
                     IsVisible="{Binding HasDescription}"
                     FontSize="11"
                     Foreground="{StaticResource Fg3Brush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:DataType="services:DialogStatusFieldItem">
      <Border MinHeight="112"
              Margin="0,0,0,10"
              Background="#82FFFFFF"
              BorderBrush="#E3E7ED"
              BorderThickness="1"
              CornerRadius="12"
              Padding="14,12">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding Label}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource Fg1Brush}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding Value}"
                     FontSize="17"
                     FontWeight="Bold"
                     Foreground="{Binding ValueForeground}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding Description}"
                     IsVisible="{Binding HasDescription}"
                     FontSize="11"
                     Foreground="{StaticResource Fg3Brush}"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </DataTemplate>

    <DataTemplate x:DataType="services:DialogActionFieldItem">
      <Border MinHeight="118"
              Margin="0,0,0,10"
              Background="#82FFFFFF"
              BorderBrush="#E3E7ED"
              BorderThickness="1"
              CornerRadius="12"
              Padding="14,12">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding Label}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource Fg1Brush}"
                     TextWrapping="Wrap"/>
          <TextBlock Text="{Binding Description}"
                     IsVisible="{Binding HasDescription}"
                     FontSize="11"
                     Foreground="{StaticResource Fg3Brush}"
                     TextWrapping="Wrap"/>
          <Button Classes="Btn BtnPill BtnGhost"
                  Command="{Binding Command}"
                  IsDefault="{Binding IsDefault}"
                  Background="{Binding ButtonBackground}"
                  Foreground="{Binding ButtonForeground}"
                  BorderBrush="{Binding ButtonBorderBrush}"
                  BorderThickness="{Binding ButtonBorderThickness}"
                  CornerRadius="11"
                  HorizontalAlignment="Left"
                  Padding="12,8">
            <TextBlock Text="{Binding ButtonText}"
                       FontWeight="SemiBold"/>
          </Button>
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Grid x:Name="OverlayRoot"
        Opacity="{Binding OverlayOpacity}"
        IsHitTestVisible="{Binding IsHitTestVisible}">
    <Grid.Transitions>
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
      </Transitions>
    </Grid.Transitions>

    <Border Background="{Binding OverlayBrush}"
            PointerPressed="OverlayMask_PointerPressed"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <Border.Transitions>
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18"/>
        </Transitions>
      </Border.Transitions>
    </Border>

      <Grid x:Name="DialogHost"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          RenderTransformOrigin="0.5,0.5">
      <Grid.Width>
        <MultiBinding Converter="{StaticResource DialogWidthRatioConverter}">
          <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                   Path="Bounds.Width"/>
          <Binding Path="DialogWidthRatio"/>
        </MultiBinding>
      </Grid.Width>
      <Grid.MaxHeight>
        <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                 Path="Bounds.Height"
                 Converter="{StaticResource MathConverter}"
                 ConverterParameter="@VALUE*0.76"/>
      </Grid.MaxHeight>
      <Grid.RenderTransform>
        <TransformGroup>
          <ScaleTransform ScaleX="{Binding CardScale}" ScaleY="{Binding CardScale}">
            <ScaleTransform.Transitions>
              <Transitions>
                <DoubleTransition Property="ScaleX" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                <DoubleTransition Property="ScaleY" Duration="0:0:0.22" Easing="CubicEaseOut"/>
              </Transitions>
            </ScaleTransform.Transitions>
          </ScaleTransform>
          <TranslateTransform X="{Binding CardOffsetX}" Y="{Binding CardOffsetY}">
            <TranslateTransform.Transitions>
              <Transitions>
                <DoubleTransition Property="X" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                <DoubleTransition Property="Y" Duration="0:0:0.2" Easing="CubicEaseOut"/>
              </Transitions>
            </TranslateTransform.Transitions>
          </TranslateTransform>
        </TransformGroup>
      </Grid.RenderTransform>

      <Border x:Name="DialogCard"
              Classes="HoverFloat"
              behaviors:HoverFloatBehavior.IsEnabled="True"
              behaviors:HoverFloatBehavior.HoverScale="1.003"
              behaviors:HoverFloatBehavior.PressScale="1"
              behaviors:HoverFloatBehavior.MaxOffsetX="0.7"
              behaviors:HoverFloatBehavior.MaxOffsetY="0.6"
              behaviors:HoverFloatBehavior.LerpFactor="0.16"
              Background="#FFFFF8F6"
              BorderBrush="#EEAAAAAA"
              BorderThickness="1"
              CornerRadius="14"
              Padding="26,28,26,24"
              BoxShadow="{StaticResource Shadow2}"
              Opacity="{Binding CardOpacity}"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center">
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
          </Transitions>
        </Border.Transitions>

        <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12" IsVisible="{Binding IsStandardOverlay}">
            <TextBlock Text="{Binding Title}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{Binding TitleForeground}"
                       Opacity="0.92"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding HeaderMeta}"
                       x:Name="DialogHeaderMetaText"
                       IsVisible="{Binding HasHeaderMeta}"
                       FontSize="13"
                       Foreground="{StaticResource Fg2Brush}"
                       Opacity="0.72"
                       HorizontalAlignment="Center"
                       Classes="HoverFloat"
                       behaviors:HoverFloatBehavior.IsEnabled="True"
                       behaviors:HoverFloatBehavior.HoverScale="1.04"
                       behaviors:HoverFloatBehavior.PressScale="0.93"
                       behaviors:HoverFloatBehavior.MaxOffsetX="1.1"
                       behaviors:HoverFloatBehavior.MaxOffsetY="0.8"
                       behaviors:HoverFloatBehavior.LerpFactor="0.18"
                       Cursor="Hand"
                       PointerPressed="DialogHeaderMetaText_PointerPressed"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
          </StackPanel>

          <ScrollViewer Grid.Row="1"
                        Margin="0,6,0,6"
                        MinHeight="0"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <i:Interaction.Behaviors>
              <ia:VerticalScrollViewerAnimatedBehavior/>
            </i:Interaction.Behaviors>
            <StackPanel Spacing="14">
              <StackPanel Spacing="10" IsVisible="{Binding IsPassiveOverlayVisible}" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{Binding TitleForeground}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
              </StackPanel>
              <Border Background="Transparent"
                      Padding="4,8,4,10"
                      Margin="0,-2,0,0"
                      ClipToBounds="False"
                      IsVisible="{Binding HasTabs}">
                <ItemsControl ItemsSource="{Binding Tabs}"
                              ClipToBounds="False">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal"
                                  Spacing="8"
                                  HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="services:DialogTabItem">
                      <Button Classes="Btn BtnGhost DialogTabButton"
                              Classes.selected="{Binding IsSelected}"
                              Command="{Binding Command}">
                        <TextBlock Text="{Binding Title}"
                                   TextWrapping="NoWrap"
                                   HorizontalAlignment="Center"/>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
              <StackPanel Spacing="8">
                <svg:Svg Path="{Binding CenterIconPath}"
                         Width="40"
                         Height="40"
                         HorizontalAlignment="Center"
                         IsVisible="{Binding HasCenterIcon}"/>
                <TextBlock Text="{Binding SectionTitle}"
                           IsVisible="{Binding HasSectionTitle}"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{StaticResource Fg1Brush}"
                           Opacity="0.9"
                           TextAlignment="Left"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding Content}"
                           IsVisible="{Binding IsStandardOverlay}"
                           FontSize="14"
                           Foreground="{StaticResource Fg2Brush}"
                           TextAlignment="Left"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SubText}"
                           IsVisible="{Binding HasSubText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{Binding SubTextForeground}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding EmphasisText}"
                           IsVisible="{Binding HasEmphasisText}"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{Binding EmphasisForeground}"
                           TextAlignment="Left"
                           HorizontalAlignment="Left"
                           TextWrapping="Wrap"/>
                <CheckBox Classes="DialogCheckbox"
                          IsVisible="{Binding HasCheckbox}"
                          IsChecked="{Binding Checkbox.IsChecked}"
                          Content="{Binding Checkbox.Text}"/>
              </StackPanel>

              <StackPanel IsVisible="{Binding HasPairedActionLinks}"
                          HorizontalAlignment="Center"
                          Spacing="10"
                          Margin="0,10,0,16"
                          ClipToBounds="False">
                <Button Classes="Btn DialogLinkButton"
                        HorizontalAlignment="Center"
                        Padding="12,7"
                        Margin="10,0"
                        Command="{Binding FirstActionLink.OpenCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <svg:Svg Path="{Binding FirstActionLink.IconPath}"
                             Width="16"
                             Height="16"/>
                    <TextBlock Text="{Binding FirstActionLink.Text}"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"/>
                  </StackPanel>
                </Button>
                <Button Classes="Btn DialogLinkButton"
                        HorizontalAlignment="Center"
                        Padding="12,7"
                        Margin="10,0"
                        Command="{Binding SecondActionLink.OpenCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <svg:Svg Path="{Binding SecondActionLink.IconPath}"
                             Width="16"
                             Height="16"/>
                    <TextBlock Text="{Binding SecondActionLink.Text}"
                               FontWeight="SemiBold"
                               TextWrapping="NoWrap"/>
                  </StackPanel>
                </Button>
              </StackPanel>

              <ItemsControl ItemsSource="{Binding FormSections}"
                            IsVisible="{Binding HasFormSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="services:DialogFormSectionItem">
                    <Border Background="#73FFFFFF"
                            BorderBrush="#E3E7ED"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="16,16,16,14"
                            Margin="0,2,0,4">
                      <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                          <TextBlock Text="{Binding Title}"
                                     FontSize="14"
                                     FontWeight="Bold"
                                     Foreground="{StaticResource Fg1Brush}"
                                     TextWrapping="Wrap"/>
                          <TextBlock Text="{Binding Description}"
                                     IsVisible="{Binding HasDescription}"
                                     FontSize="12"
                                     Foreground="{StaticResource Fg3Brush}"
                                     TextWrapping="Wrap"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Items}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                        </ItemsControl>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <ItemsControl ItemsSource="{Binding ExpandableSections}"
                            IsVisible="{Binding HasExpandableSections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="services:DialogExpandableSectionItem">
                    <Border Background="Transparent"
                            BorderBrush="#00FFFFFF"
                            BorderThickness="0"
                            CornerRadius="12"
                            Padding="18,8,18,6"
                            Margin="12,0,12,10"
                            ClipToBounds="False">
                      <StackPanel Spacing="0"
                                  MinWidth="250">
                        <Button Classes="Btn DialogSectionToggle"
                                Command="{Binding ToggleCommand}">
                          <Button.Width>
                            <Binding ElementName="DialogCard"
                                     Path="Bounds.Width"
                                     Converter="{StaticResource MathConverter}"
                                     ConverterParameter="@VALUE*0.8"/>
                          </Button.Width>
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Title}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Fg1Brush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="⌄"
                                       FontSize="13"
                                       Foreground="{StaticResource Fg2Brush}"
                                       VerticalAlignment="Center"/>
                          </Grid>
                        </Button>

                        <Border MaxHeight="0"
                                Opacity="0"
                                IsHitTestVisible="False"
                                ClipToBounds="True"
                                Background="Transparent"
                                Padding="8,0,8,14"
                                AttachedToVisualTree="AnimatedContainer_AttachedToVisualTree"
                                DetachedFromVisualTree="AnimatedContainer_DetachedFromVisualTree"
                                PointerPressed="ExpandableSectionContent_PointerPressed">
                          <Border.RenderTransform>
                            <ScaleTransform ScaleY="0.96"/>
                          </Border.RenderTransform>
                          <Border.RenderTransformOrigin>
                            0.5,0
                          </Border.RenderTransformOrigin>
                          <Border.Transitions>
                            <Transitions>
                              <DoubleTransition Property="MaxHeight" Duration="0:0:0.24" Easing="CubicEaseOut"/>
                              <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                              <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.24" Easing="CubicEaseOut"/>
                            </Transitions>
                          </Border.Transitions>
                          <StackPanel Spacing="0">
                            <ItemsControl ItemsSource="{Binding Items}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="services:DialogLicenseItem">
                                  <Border BorderBrush="#E8E8EC"
                                          BorderThickness="0,1,0,0"
                                          Padding="0,12,0,0">
                                    <StackPanel Spacing="8">
                                      <TextBlock Text="{Binding Title}"
                                                 FontSize="14"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource Fg1Brush}"
                                                 TextWrapping="Wrap"/>
                                      <TextBlock Text="{Binding MetaText}"
                                                 IsVisible="{Binding HasMetaText}"
                                                 FontSize="12"
                                                 Foreground="{StaticResource Fg3Brush}"
                                                 TextWrapping="Wrap"/>
                                      <TextBlock Text="{Binding Summary}"
                                                 IsVisible="{Binding HasSummary}"
                                                 FontSize="13"
                                                 Foreground="{StaticResource Fg2Brush}"
                                                 TextWrapping="Wrap"/>

                                      <WrapPanel Orientation="Horizontal" ItemHeight="28">
                                        <Button Classes="DialogInlineLink"
                                                Margin="0,0,14,0"
                                                IsVisible="{Binding HasProjectUrl}"
                                                Command="{Binding OpenProjectCommand}">
                                          <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Dialog_Link_Project]}"
                                                     TextDecorations="Underline"/>
                                        </Button>
                                        <Button Classes="DialogInlineLink"
                                                Margin="0,0,14,0"
                                                IsVisible="{Binding HasLicenseUrl}"
                                                Command="{Binding OpenLicenseCommand}">
                                          <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Dialog_Link_License]}"
                                                     TextDecorations="Underline"/>
                                        </Button>
                                      </WrapPanel>

                                      <StackPanel Spacing="8"
                                                  IsVisible="{Binding HasFullText}">
                                        <Button Classes="Btn DialogTextToggle"
                                                Command="{Binding ToggleTextCommand}">
                                          <Button.Width>
                                            <Binding ElementName="DialogCard"
                                                     Path="Bounds.Width"
                                                     Converter="{StaticResource MathConverter}"
                                                     ConverterParameter="@VALUE*0.52"/>
                                          </Button.Width>
                                          <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Dialog_License_Toggle]}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Fg1Brush}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="⌄"
                                                       FontSize="12"
                                                       Foreground="{StaticResource Fg2Brush}"/>
                                          </Grid>
                                        </Button>

                                        <Border Background="#7AFFFFFF"
                                                BorderBrush="#E1E4EA"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,2,0,0"
                                                MaxHeight="0"
                                                Opacity="0"
                                                IsHitTestVisible="False"
                                                ClipToBounds="True"
                                                AttachedToVisualTree="AnimatedContainer_AttachedToVisualTree"
                                                DetachedFromVisualTree="AnimatedContainer_DetachedFromVisualTree"
                                                PointerPressed="LicenseTextContainer_PointerPressed">
                                          <Border.RenderTransform>
                                            <ScaleTransform ScaleY="0.96"/>
                                          </Border.RenderTransform>
                                          <Border.RenderTransformOrigin>
                                            0.5,0
                                          </Border.RenderTransformOrigin>
                                          <Border.Transitions>
                                            <Transitions>
                                              <DoubleTransition Property="MaxHeight" Duration="0:0:0.24" Easing="CubicEaseOut"/>
                                              <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                                              <DoubleTransition Property="ScaleTransform.ScaleY" Duration="0:0:0.24" Easing="CubicEaseOut"/>
                                            </Transitions>
                                          </Border.Transitions>
                                          <TextBlock Text="{Binding FullText}"
                                                     FontFamily="Cascadia Mono,Consolas,Monospace"
                                                     FontSize="12"
                                                     Foreground="{StaticResource Fg2Brush}"
                                                     TextWrapping="Wrap"/>
                                        </Border>
                                      </StackPanel>
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <StackPanel Spacing="8"
                          IsVisible="{Binding ShowProgress}">
                <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Value="{Binding ProgressValue}"
                             Height="8"
                             CornerRadius="8"/>
              </StackPanel>

              <Border IsVisible="{Binding HasCodeBlock}"
                      x:Name="DialogCodeBlockHost"
                      Classes="HoverFloat"
                      behaviors:HoverFloatBehavior.IsEnabled="True"
                      behaviors:HoverFloatBehavior.HoverScale="1.02"
                      behaviors:HoverFloatBehavior.PressScale="0.97"
                      behaviors:HoverFloatBehavior.MaxOffsetX="1.3"
                      behaviors:HoverFloatBehavior.MaxOffsetY="1.1"
                      Background="#7AFFFFFF"
                      BorderBrush="#E1E4EA"
                      BorderThickness="1"
                      CornerRadius="12"
                      Padding="10">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Dialog_CodeBlock_SelectAll]}"
                              Click="CodeBlockSelectAllMenuItem_Click"/>
                    <MenuItem Header="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Dialog_CodeBlock_Copy]}"
                              Click="CodeBlockCopyMenuItem_Click"/>
                  </ContextMenu>
                </Border.ContextMenu>
                <ScrollViewer x:Name="DialogCodeBlockScrollViewer"
                              Classes="HoverFloat"
                              behaviors:HoverFloatBehavior.IsEnabled="True"
                              behaviors:HoverFloatBehavior.HoverScale="1.02"
                              behaviors:HoverFloatBehavior.PressScale="0.97"
                              behaviors:HoverFloatBehavior.MaxOffsetX="1.2"
                              behaviors:HoverFloatBehavior.MaxOffsetY="1"
                              behaviors:HoverFloatBehavior.LerpFactor="0.2"
                              MinHeight="160"
                              MaxHeight="160"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <i:Interaction.Behaviors>
                    <ia:VerticalScrollViewerAnimatedBehavior/>
                  </i:Interaction.Behaviors>
                  <SelectableTextBlock x:Name="DialogCodeBlockTextBox"
                                       Focusable="False"
                                       FocusAdorner="{x:Null}"
                                       SelectionBrush="#338FB3D9"
                                       TextWrapping="Wrap"
                                       Text="{Binding CodeBlock.Content}"/>
                </ScrollViewer>
              </Border>
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Row="2"
                      Margin="0,14,0,0"
                      Spacing="12"
                      IsVisible="{Binding ShowActionButtons}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="12">
              <Button Classes="Btn BtnPill"
                      x:Name="PrimaryButton"
                      Background="{Binding PrimaryBackground}"
                      Foreground="{Binding PrimaryForeground}"
                      BorderBrush="{Binding PrimaryBorderBrush}"
                      BorderThickness="{Binding PrimaryBorderThickness}"
                      CornerRadius="12"
                      Padding="14,10"
                      MinWidth="110"
                      Opacity="0.75"
                      Command="{Binding PrimaryActionCommand}"
                      IsVisible="{Binding ShowPrimaryButtonEffective}">
                <Button.Width>
                  <MultiBinding Converter="{StaticResource DialogButtonWidthConverter}">
                    <Binding ElementName="DialogCard" Path="Bounds.Width"/>
                    <Binding Path="HasSecondaryButton"/>
                  </MultiBinding>
                </Button.Width>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="6">
                  <TextBlock Text="{Binding PrimaryButtonText}"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center"/>
                  <TextBlock Text="{Binding PrimaryCountdownText}"
                             IsVisible="{Binding PrimaryCountdownVisible}"
                             Foreground="{StaticResource Fg3Brush}"
                             Opacity="0.8"
                             FontSize="12"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button Classes="Btn BtnPill BtnGhost"
                      BorderBrush="{Binding SecondaryBorderBrush}"
                      Foreground="{Binding SecondaryForeground}"
                      Background="{Binding SecondaryBackground}"
                      BorderThickness="{Binding SecondaryBorderThickness}"
                      CornerRadius="12"
                      Padding="14,10"
                      MinWidth="110"
                      Opacity="0.75"
                      Command="{Binding SecondaryActionCommand}"
                      IsVisible="{Binding ShowSecondaryButtonEffective}">
                <Button.Width>
                  <MultiBinding Converter="{StaticResource DialogButtonWidthConverter}">
                    <Binding ElementName="DialogCard" Path="Bounds.Width"/>
                    <Binding Path="HasSecondaryButton"/>
                  </MultiBinding>
                </Button.Width>
                <TextBlock Text="{Binding SecondaryButtonText}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
              </Button>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

  </Grid>
</UserControl>
