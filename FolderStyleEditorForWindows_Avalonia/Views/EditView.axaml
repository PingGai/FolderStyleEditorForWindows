<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
            xmlns:vm="using:FolderStyleEditorForWindows.ViewModels"
            xmlns:services="using:FolderStyleEditorForWindows.Services"
            xmlns:controls="using:FolderStyleEditorForWindows.Controls"
            xmlns:i="using:Avalonia.Xaml.Interactivity"
            xmlns:ia="using:Avalonia.Xaml.Interactions.Animated"
            xmlns:behaviors="using:FolderStyleEditorForWindows.Behaviors"
            xmlns:sys="using:System"
            mc:Ignorable="d" d:DesignWidth="404" d:DesignHeight="762"
            x:Class="FolderStyleEditorForWindows.Views.EditView"
            x:DataType="vm:MainViewModel">
   <UserControl.Styles>
        <Style Selector="Button#btnOpenExplorer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="behaviors:HoverFloatBehavior.IsEnabled" Value="True"/>
            <Setter Property="behaviors:HoverFloatBehavior.HoverScale" Value="1.03"/>
            <Setter Property="behaviors:HoverFloatBehavior.PressScale" Value="0.96"/>
            <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetX" Value="1.2"/>
            <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetY" Value="0.6"/>
            <Setter Property="behaviors:HoverFloatBehavior.LerpFactor" Value="0.18"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource Fg2Brush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button#btnOpenExplorer:pointerover">
            <Setter Property="Opacity" Value="0.76"/>
        </Style>
        <Style Selector="ListBox#iconListBox ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource PreviewBrush}"/>
        </Style>
        <Style Selector="ListBox#iconListBox ListBoxItem.previewed /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource PreviewBrush}"/>
        </Style>
        <Style Selector="ListBox#iconListBox ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight2}"/>
        </Style>
        <Style Selector="ListBox#iconListBox ListBoxItem:selected.previewed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorLight2}"/>
        </Style>
        <Style Selector="Button.AliasAutocompleteItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="behaviors:HoverFloatBehavior.IsEnabled" Value="True"/>
            <Setter Property="behaviors:HoverFloatBehavior.HoverScale" Value="1.03"/>
            <Setter Property="behaviors:HoverFloatBehavior.PressScale" Value="0.96"/>
            <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetX" Value="1.2"/>
            <Setter Property="behaviors:HoverFloatBehavior.MaxOffsetY" Value="0.9"/>
        </Style>
        <Style Selector="Button.AliasAutocompleteItem:pointerover">
            <Setter Property="Background" Value="#EEF1F6"/>
        </Style>
        <Style Selector="TextBlock#aliasGhostText">
            <Setter Property="Foreground" Value="{StaticResource Fg3Brush}"/>
            <Setter Property="Opacity" Value="0.84"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>
   </UserControl.Styles>
   <UserControl.Resources>
        <LinearGradientBrush x:Key="EditTitleGoldAnimatedBrush"
                             StartPoint="0%,34%"
                             EndPoint="160%,66%"
                             SpreadMethod="Repeat">
            <GradientStop Color="#FFB347" Offset="0"/>
            <GradientStop Color="#FFD56A" Offset="0.2"/>
            <GradientStop Color="#FFF1A3" Offset="0.4"/>
            <GradientStop Color="#E0A93F" Offset="0.6"/>
            <GradientStop Color="#FFD07A" Offset="0.8"/>
            <GradientStop Color="#FFB347" Offset="1"/>
        </LinearGradientBrush>
        <DataTemplate x:Key="IconDataTemplate" x:DataType="vm:IconViewModel">
            <Border Classes="IcoCell"
                    BorderThickness="1"
                    BorderBrush="{StaticResource LineBrush}"
                    Background="Transparent"
                    Width="48"
                    Height="48">
                <ToolTip.Tip>
                    <TextBlock Text="{Binding Index, StringFormat='绱㈠紩: {0}'}"/>
                </ToolTip.Tip>
                <Grid RowDefinitions="*,Auto" Margin="2">
                    <Image Source="{Binding Image}" Grid.Row="0" Width="32" Height="32" Margin="4"/>
                    <TextBlock Text="{Binding Index}" Grid.Row="1" FontSize="10" HorizontalAlignment="Center" Foreground="{StaticResource Fg3Brush}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
   <Grid>
        <!-- Title Bar -->
        <DockPanel VerticalAlignment="Top" Height="54">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,0">
               <controls:TitleBarButtons Grid.Column="0"
                                         Grid.ColumnSpan="3"
                                         ShowBack="True"
                                         ShowMinimize="True"
                                         ShowClose="True"
                                         BackRequested="TitleBarButtons_BackRequested"/>
               <Button Name="EditTitleButton"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Background="Transparent"
                       BorderBrush="Transparent"
                       BorderThickness="0"
                       Padding="6,2"
                       Classes="HoverFloat"
                       behaviors:HoverFloatBehavior.IsEnabled="True"
                       behaviors:HoverFloatBehavior.HoverScale="1.04"
                       behaviors:HoverFloatBehavior.PressScale="0.92"
                       behaviors:HoverFloatBehavior.MaxOffsetX="1.5"
                       behaviors:HoverFloatBehavior.MaxOffsetY="1"
                       behaviors:HoverFloatBehavior.LerpFactor="0.2">
                   <TextBlock Name="EditTitleText"
                              Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Title]}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Foreground="{StaticResource Fg1Brush}"
                              Opacity="0.8"
                              FontSize="16"
                              FontWeight="SemiBold"/>
               </Button>
            </Grid>
        </DockPanel>

        <!-- Main Scrollable Content -->
     <ScrollViewer Margin="0,54,0,0" Name="editScrollViewer">
         <i:Interaction.Behaviors>
             <ia:VerticalScrollViewerAnimatedBehavior/>
             <behaviors:AutoHideScrollBehavior/>
         </i:Interaction.Behaviors>
         <StackPanel Spacing="8" Margin="12,12,12,120">
             
             <!-- Directory Card -->
                <Border Classes="Card">
                    <StackPanel Spacing="10">
                     <Grid ColumnDefinitions="*,Auto">
                         <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Directory_Title]}" Classes="Subtitle" VerticalAlignment="Center"/>
                         <Button Name="btnOpenExplorer" Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Directory_OpenExplorer]}" Grid.Column="1" Margin="0,2,0,0"/>
                     </Grid>
                     <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                         <TextBox Name="pathInput" Text="{Binding FolderPath}" Grid.Column="0" Watermark="C:\Users\Me\Pictures" Classes="Input"/>
                         <Button Name="btnPickDir" Grid.Column="1" Classes="Btn">
                               <StackPanel Orientation="Horizontal" Spacing="8">
                                   <PathIcon Data="M3 7h5l2 2h11v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/>
                                   <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Directory_Select]}"/>
                               </StackPanel>
                           </Button>
                       </Grid>
                       <TextBlock Name="pathError" Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Directory_Invalid]}" Classes="ErrorTip"/>
                    </StackPanel>
                </Border>

                <!-- Drag Tip -->
                <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_DragTip]}" Classes="Note" HorizontalAlignment="Center" Margin="0,10,0,8"/>

                <!-- Info Card -->
                <Border Classes="Card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Info_Title]}" Classes="Subtitle"/>
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Alias_Label]}" Classes="Body"/>
                        <Grid x:Name="AliasAutocompleteHost"
                              ClipToBounds="False">
                            <Grid>
                                <TextBlock Name="aliasGhostText"
                                           Text="{Binding AliasAutocompletePreviewText}"
                                           IsVisible="{Binding HasAliasAutocompleteInlineSuffix}"
                                           VerticalAlignment="Center"
                                           Margin="13,-1,12,0"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource Fg3Brush}"
                                           RenderTransform="{Binding #aliasInput.RenderTransform}"
                                           RenderTransformOrigin="{Binding #aliasInput.RenderTransformOrigin}"/>
                                <TextBox Name="aliasInput"
                                         Text="{Binding Alias}"
                                         Background="#01FFFFFF"
                                         Watermark="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Alias_Watermark]}"
                                         Classes="Input"
                                         Classes.placeholder="{Binding IsAliasAsPlaceholder}">
                                    <TextBox.Styles>
                                        <Style Selector="TextBox.Input.placeholder">
                                            <Setter Property="Foreground" Value="{StaticResource Fg3Brush}"/>
                                        </Style>
                                    </TextBox.Styles>
                                </TextBox>
                            </Grid>
                            <Popup Name="aliasAutocompletePopup"
                                   Placement="Bottom"
                                   HorizontalOffset="0"
                                   VerticalOffset="8"
                                   IsOpen="{Binding IsAliasAutocompleteExpanded}">
                                <Border Background="Transparent"
                                        Padding="8"
                                        ClipToBounds="False">
                                    <Border Background="#F6FFFFFF"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="8"
                                            BoxShadow="{StaticResource Shadow1}"
                                            MinWidth="{Binding #aliasInput.Bounds.Width}">
                                        <ScrollViewer MaxHeight="150"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto"
                                                      PointerWheelChanged="AliasAutocompleteScrollViewer_PointerWheelChanged">
                                            <i:Interaction.Behaviors>
                                                <ia:VerticalScrollViewerAnimatedBehavior/>
                                                <behaviors:AutoHideScrollBehavior/>
                                            </i:Interaction.Behaviors>
                                            <ItemsControl ItemsSource="{Binding AliasAutocompleteCandidates}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:MainViewModel+AliasAutocompleteItemViewModel">
                                                        <Button Classes="AliasAutocompleteItem"
                                                                Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='PreviewBrush'}"
                                                                Margin="0,0,0,6"
                                                                PointerPressed="AliasAutocompleteCandidate_PointerPressed"
                                                                >
                                                            <TextBlock Text="{Binding Text}"
                                                                       Foreground="{StaticResource Fg2Brush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>
                                </Border>
                            </Popup>
                        </Grid>

                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Icon_Label]}" Classes="Body" Margin="0,14,0,0"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBox Name="iconInput" Text="{Binding IconPath}" Watermark="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Icon_Watermark]}" Grid.Column="0" Classes="Input"/>
                            <Button Name="btnPickIcon" Grid.Column="1" Classes="Btn">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="M3 7h5l2 2h11v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/>
                                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Icon_Select]}"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Classes="IconPicker" Margin="0,10,0,0">
                            <Grid>
                                <ScrollViewer Name="iconListScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Height="182">
                                    <i:Interaction.Behaviors>
                                        <ia:VerticalScrollViewerAnimatedBehavior/>
                                        <behaviors:AutoHideScrollBehavior/>
                                    </i:Interaction.Behaviors>
                                    <ListBox Name="iconListBox"
                                             Focusable="True"
                                             ItemsSource="{Binding Icons}"
                                             ItemTemplate="{StaticResource IconDataTemplate}"
                                             SelectedItem="{Binding SelectedIcon, Mode=TwoWay}"
                                             Background="Transparent"
                                             BorderThickness="0">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                </ScrollViewer>

                                <!-- 加载指示器 -->
                                <ProgressBar IsIndeterminate="True"
                                             IsVisible="{Binding IsLoadingIconsIndicatorVisible}"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             Margin="20,0"/>
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Icon_Loading]}"
                                           IsVisible="{Binding IsLoadingIconsIndicatorVisible}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource Fg2Brush}"
                                           Margin="0,30,0,0"/>
                            </Grid>
                        </Border>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" Margin="0,12,0,0">
                           <!-- 保留原有的重置图标按钮 -->
                           <Button Name="btnResetIcon" Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Icon_Reset]}" Classes="Btn" Grid.Column="0" Command="{Binding ResetIconCommand}"/>
                           
                           <!-- 自动获取按钮用于快速提取图标 -->
                           <Button Name="btnAutoGetIcon" Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Icon_AutoGet]}" Classes="Btn" Grid.Column="1" Command="{Binding AutoGetIconCommand}"/>
                           
                           <!-- 右侧区域显示图标序号、总数与跳转入口 -->
                           <StackPanel Grid.Column="2"
                                       Orientation="Horizontal"
                                       Spacing="4"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding IsIconCounterVisible}">
                               <Border Name="iconCounterHost"
                                       Padding="4,0"
                                       Background="Transparent"
                                       ToolTip.Tip="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_IconCounter_ScrollHint]}">
                                   <Grid>
                                       <TextBlock Name="iconCounterDisplay"
                                                  Text="{Binding IconCounterNumerator}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Fg2Brush}"
                                                   FontWeight="SemiBold"
                                                   Cursor="Hand"
                                                   TextDecorations="Underline"
                                                   RenderTransformOrigin="0.5,0.5">
                                           <TextBlock.RenderTransform>
                                               <ScaleTransform ScaleX="1" ScaleY="1"/>
                                           </TextBlock.RenderTransform>
                                           <ToolTip.Tip>
                                               <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_IconCounter_ScrollHint]}"/>
                                           </ToolTip.Tip>
                                       </TextBlock>
                                       <TextBox Name="iconCounterInput"
                                                Text="{Binding IconCounterNumerator}"
                                                IsVisible="False"
                                                MinWidth="28"
                                                MaxWidth="48"
                                                Padding="0"
                                                BorderThickness="0"
                                                Background="Transparent"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                ToolTip.Tip="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_IconCounter_ScrollHint]}"
                                                FontWeight="SemiBold"/>
                                   </Grid>
                               </Border>
                               <TextBlock Text="/"
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource Fg2Brush}"
                                          FontWeight="SemiBold"/>
                               <TextBlock Text="{Binding IconCounterDenominator}"
                                          VerticalAlignment="Center"
                                          Foreground="{StaticResource Fg2Brush}"
                                          FontWeight="SemiBold"/>
                           </StackPanel>
                       </Grid>
                    </StackPanel>
                </Border>

                <!-- Reset Card -->
                <Border Classes="Card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Reset_Title]}" Classes="Subtitle"/>
                        <Button Name="btnClearAll" Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_Reset_ClearAll]}" Classes="Btn BtnDanger" Command="{Binding ClearAllStylesCommand}"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Save Bar -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,18">
            <Button Name="btnSave" Content="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Edit_SaveButton]}" Classes="Btn BtnPill" MinWidth="220" Command="{Binding SaveCommand}"/>
        </Border>
        
    </Grid>
</UserControl>
