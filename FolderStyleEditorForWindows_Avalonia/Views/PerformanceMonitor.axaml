<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:FolderStyleEditorForWindows.Services"
             xmlns:behaviors="using:FolderStyleEditorForWindows.Behaviors"
             x:Class="FolderStyleEditorForWindows.Views.PerformanceMonitor"
             x:DataType="services:PerformanceMonitorViewModel"
             IsVisible="{Binding IsVisible}">
    <Border Background="Transparent"
            Padding="14,14,14,20"
            Margin="0,0,0,2"
            ClipToBounds="False">
        <Border x:Name="MonitorRoot"
                Background="#C0F9FBFD"
                BorderBrush="#D9DFE4EA"
                BorderThickness="1"
                CornerRadius="16"
                Padding="12,10"
                Opacity="0.75"
                behaviors:HoverFloatBehavior.IsEnabled="True"
                behaviors:HoverFloatBehavior.HoverScale="1.045"
                behaviors:HoverFloatBehavior.PressScale="0.965"
                behaviors:HoverFloatBehavior.MaxOffsetX="2.8"
                behaviors:HoverFloatBehavior.MaxOffsetY="2.8"
                behaviors:HoverFloatBehavior.LerpFactor="0.22"
                ClipToBounds="False"
                BoxShadow="{StaticResource Shadow1}">
            <Border.ContextMenu>
                <ContextMenu x:Name="MonitorContextMenu">
                    <MenuItem Header="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[Dialog_FrameRate_Secondary_Close]}"
                              Click="CloseMenuItem_OnClick"/>
                </ContextMenu>
            </Border.ContextMenu>
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" Easing="CubicEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_WindowFps]}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Fg3Brush}"/>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <TextBlock Text="{Binding WindowApproxFps}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Fg1Brush}"/>
                        <TextBlock Text="{Binding RenderMode}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg3Brush}"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_AppCpu]}"
                               FontSize="11"
                               Foreground="{StaticResource Fg2Brush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding AppCpuDisplay}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Fg1Brush}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_SystemCpu]}"
                               FontSize="11"
                               Opacity="0.64"
                               Foreground="{StaticResource Fg3Brush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SystemCpuDisplay}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Opacity="0.76"
                               Foreground="{StaticResource Fg2Brush}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_AppGpu]}"
                               FontSize="11"
                               Foreground="{StaticResource Fg2Brush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding AppGpuDisplay}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Fg1Brush}"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_SystemGpu]}"
                               FontSize="11"
                               Opacity="0.64"
                               Foreground="{StaticResource Fg3Brush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SystemGpuDisplay}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Opacity="0.76"
                               Foreground="{StaticResource Fg2Brush}"/>
                </Grid>

                <Border Height="1"
                        Background="#E4E8EE"
                        Margin="0,2,0,0"
                        IsVisible="{Binding IsDetailedVisible}"/>

                <StackPanel Spacing="4"
                            IsVisible="{Binding IsDetailedVisible}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_Foreground]}"
                                   FontSize="11"
                                   Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ForegroundDisplay}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg1Brush}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_Static]}"
                                   FontSize="11"
                                   Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding StaticDisplay}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg1Brush}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_Background]}"
                                   FontSize="11"
                                   Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding BackgroundAmbientDisplay}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg1Brush}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_HomeTitle]}"
                                   FontSize="11"
                                   Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding HomeTitleAmbientDisplay}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg1Brush}"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Label_AdminTitle]}"
                                   FontSize="11"
                                   Foreground="{StaticResource Fg2Brush}"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding AdminTitleAmbientDisplay}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fg1Brush}"/>
                    </Grid>
                    <TextBlock Text="{Binding Source={x:Static services:LocalizationManager.Instance}, Path=[PerformanceMonitor_Note_AppMetrics]}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               FontSize="10"
                               Opacity="0.72"
                               Foreground="{StaticResource Fg3Brush}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
